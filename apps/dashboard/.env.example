# Openship Dashboard — local dev. Copy to `.env`; `dev` loads it (node --env-file=.env).
# Non-secret runtime config: the mode lives HERE, not in a wrapper script.
# OPENSHIP_TARGET selects the runtime-target row in packages/core/runtime-config.ts.
OPENSHIP_TARGET=local
OPENSHIP_CLOUD_TARGET=local-saas
PORT=3001
NEXT_DIST_DIR=.next
